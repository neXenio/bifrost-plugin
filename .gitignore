# Secrets — never commit keys or env files
.env
.env.*
*.key
*.pem
*_VK=*
*vk_*.txt

# Node
node_modules/
dist/
.cache/

# Plugin MCP config — must ship. Override any global gitignore that excludes .mcp.json.
!.mcp.json

# Local state & staging
# Note: the plugin's runtime cache lives at ~/.cache/bifrost-plugin/ (outside the
# repo), so no ignore rule is needed — git does not expand ~ in .gitignore anyway.
.bifrost-plugin-cache/

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*.swo

.omc/
.DS_Store

# Internal handover / working docs — not part of the shipped plugin
HANDOVER-*.md
temp/
